{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "melorium-launcher",
  "version": "0.1.0",
  "identifier": "primalcat.melorium",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "melorium-launcher",
        "width": 1100,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4Mjk3Q0VGMDlDRTRBMQpSV1NoNUp6d3pwZUNDNmE2RVlYS0JNWHljbDYxNVJMTVMvQnVUREVEekRRcHFmaU1ZT2dEMVhPMwo=",
      "endpoints": [],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
