# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.claude

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# tauri signing keys
.tauri/
*.key
*.key.pub

# tauri build output (also in src-tauri/.gitignore but kept here for clarity)
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/cargo-errors.json

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local settings
.claude/settings.local.json
